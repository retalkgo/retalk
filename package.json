{
	"private": true,
	"packageManager": "pnpm@8.7.0",
	"scripts": {
		"build": "nr build:packages && nr build:apidoc && nr generate:swagger",
		"build:apidoc": "redocly build-docs docs/swagger.yaml -o apidoc/index.html",
		"build:packages": "pnpm -r run build",
		"dev": "npm -C ./packages/client run dev",
		"generate:swagger": "sta -p ./docs/swagger.yaml -o ./packages/api/src -n swagger.ts && nr lint:fix",
		"lint": "eslint . && prettier . --check",
		"lint:fix": "eslint . --fix && prettier . --write",
		"release": "bumpp packages/*/package.json --commit --push --tag && nr build:packages && pnpm publish -r --filter ./packages/*",
		"serve:apidoc": "serve apidoc",
		"stub": "pnpm -r run stub",
		"test": "vitest",
		"typecheck": "vitest typecheck"
	},
	"devDependencies": {
		"@antfu/ni": "^0.21.5",
		"@redocly/cli": "^1.0.2",
		"@so1ve/eslint-config-solid": "^0.119.3",
		"@so1ve/prettier-config": "^0.120.0",
		"@types/node": "^20.4.9",
		"bumpp": "^9.2.0",
		"execa": "^7.1.1",
		"pkgroll": "^1.10.0",
		"prettier": "^3.0.0",
		"rimraf": "^3.0.2",
		"serve": "^14.2.0",
		"swagger-typescript-api": "^13.0.3",
		"tsx": "^3.12.7",
		"typescript": "^5.1.6",
		"unbuild": "^1.2.1",
		"vite": "^4.4.6",
		"vitest": "^0.34.1"
	},
	"pnpm": {
		"packageExtensions": {
			"@redocly/cli": {
				"dependencies": {
					"node-fetch": "^2"
				}
			}
		}
	}
}
