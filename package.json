{
	"private": true,
	"packageManager": "pnpm@8.6.12",
	"scripts": {
		"build": "turbo build",
		"build:apidoc": "redocly build-docs docs/swagger.yaml -o apidoc/index.html",
		"dev": "npm -C ./packages/client run dev",
		"generate:swagger-types": "sta -p ./docs/swagger.yaml -o ./packages/api/src -n swagger.ts",
		"lint": "eslint . && prettier . --check",
		"lint:fix": "eslint . --fix && prettier . --write",
		"serve:apidoc": "serve apidoc",
		"stub": "turbo stub",
		"test": "vitest",
		"typecheck": "vitest typecheck"
	},
	"devDependencies": {
		"@redocly/cli": "^1.0.2",
		"@so1ve/eslint-config-solid": "^0.119.2",
		"@so1ve/prettier-config": "^0.119.2",
		"@types/node": "^20.4.9",
		"execa": "^7.1.1",
		"pkgroll": "^1.10.0",
		"prettier": "^3.0.0",
		"rimraf": "^3.0.2",
		"serve": "^14.2.0",
		"swagger-typescript-api": "^13.0.3",
		"tsx": "^3.12.7",
		"turbo": "^1.10.9",
		"typescript": "^5.1.6",
		"unbuild": "^1.2.1",
		"vite": "^4.4.6",
		"vitest": "^0.34.1"
	}
}
