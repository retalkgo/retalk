{
  "name": "@retalkgo/client",
  "version": "0.0.0",
  "type": "module",
  "description": "Retalk client",
  "keywords": [
    "comment",
    "solid"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/retalk.cjs",
      "import": "./dist/retalk.mjs",
      "browser": "./dist/retalk.umd.js"
    }
  },
  "main": "./dist/retalk.cjs",
  "module": "./dist/retalk.mjs",
  "browser": "./dist/retalk.umd.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "format": "prettier -w .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "solid-js": "^1.7.7"
  },
  "devDependencies": {
    "@mojojoejo/vite-plugin-purgecss": "^1.1.0",
    "@unocss/preset-rem-to-px": "^0.53.4",
    "@unocss/preset-uno": "^0.53.4",
    "unocss": "^0.53.4",
    "vite": "^4.4.1",
    "vite-plugin-dts": "^2.3.0",
    "vite-plugin-solid": "^2.7.0"
  }
}
