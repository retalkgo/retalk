{
	"name": "@retalkgo/client",
	"version": "0.1.0-alpha.0",
	"author": "Ray <i@mk1.io> (https://github.com/so1ve)",
	"description": "Retalk client",
	"keywords": [
		"comment",
		"solid"
	],
	"homepage": "https://github.com/retalkgo/retalk/tree/main/packages/schema#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/retalkgo/retalk.git",
		"directory": "/"
	},
	"bugs": {
		"url": "https://github.com/retalkgo/retalk/issues"
	},
	"license": "MIT",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/retalk.d.ts",
			"require": "./dist/retalk.cjs",
			"import": "./dist/retalk.mjs",
			"browser": "./dist/retalk.umd.js"
		},
		"./retalk.css": {
			"types": "./dist/retalk.css",
			"require": "./dist/retalk.css",
			"import": "./dist/retalk.css",
			"browser": "./dist/retalk.css"
		}
	},
	"main": "./dist/retalk.cjs",
	"module": "./dist/retalk.mjs",
	"browser": "./dist/retalk.umd.js",
	"types": "./dist/retalk.d.ts",
	"typesVersions": {
		"*": {
			"*": [
				"./dist/*",
				"./dist/retalk.d.ts"
			]
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsx scripts/build.ts",
		"build:real": "vite build",
		"dev": "vite",
		"preview": "vite preview"
	},
	"dependencies": {
		"@retalkgo/api": "workspace:*",
		"@retalkgo/utils": "workspace:*",
		"solid-js": "^1.7.8"
	},
	"devDependencies": {
		"@mojojoejo/vite-plugin-purgecss": "^1.1.0",
		"@unocss/preset-rem-to-px": "^0.55.0",
		"@unocss/preset-uno": "^0.55.0",
		"unocss": "^0.55.0",
		"vite-plugin-dts": "^3.3.1",
		"vite-plugin-solid": "^2.7.0",
		"vite-tsconfig-paths": "^4.2.0"
	}
}
