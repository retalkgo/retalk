{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"skipLibCheck": true,
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"strict": true,
		"noFallthroughCasesInSwitch": true,
		"paths": {
			"@retalkgo/client": ["./packages/client/src/index.ts"],
			"@retalkgo/utils": ["./packages/utils/src/index.ts"],
			"@retalkgo/api": ["./packages/api/src/index.ts"]
		}
	},
	}
