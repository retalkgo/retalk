{
  "name": "@retalkgo/client",
  "version": "0.0.0",
  "packageManager": "pnpm@8.6.1",
  "type": "module",
  "description": "Retalk client",
  "keywords": [
    "comment",
    "solid"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/retalk.cjs",
      "import": "./dist/retalk.mjs",
      "browser": "./dist/retalk.umd.js"
    }
  },
  "main": "./dist/retalk.cjs",
  "module": "./dist/retalk.mjs",
  "types": "./dist/index.d.ts",
  "browser": "./dist/retalk.umd.js",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && vite build",
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "solid-js": "^1.7.6"
  },
  "devDependencies": {
    "@so1ve/eslint-config-solid": "^0.100.0",
    "@types/node": "^18.16.16",
    "prettier": "^2.8.8",
    "rimraf": "3",
    "typescript": "^5.0.2",
    "unocss": "^0.53.1",
    "vite": "^4.3.9",
    "vite-plugin-dts": "^2.3.0",
    "vite-plugin-solid": "^2.7.0"
  }
}
